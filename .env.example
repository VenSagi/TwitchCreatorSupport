# --- Postgres (Docker: docker compose up -d) ---
# Port 5433 matches docker-compose (Postgres in container still uses 5432 internally).
# If you change the host port in docker-compose.yml, update this URL to match.
DATABASE_URL=postgresql://hypeforge:hypeforge@127.0.0.1:5433/hypeforge?sslmode=disable

# --- Redis (BullMQ worker + queue) ---
REDIS_URL=redis://127.0.0.1:6379

# --- API (NestJS, default port 3001) ---
PORT=3001
WEB_APP_URL=http://localhost:3000

# Clerk — create an application at https://dashboard.clerk.com
# Use the same secret in the API and the "Secret key" in Clerk dashboard for backend.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Stripe — test mode keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
# Webhook signing secret from `stripe listen` or Stripe Dashboard webhook endpoint
STRIPE_WEBHOOK_SECRET=

# --- Next.js (apps/web) ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
NEXT_PUBLIC_DEFAULT_CREATOR_ID=seed_creator_avalive
